#!/bin/bash
#SBATCH --job-name=JUM_pipeline
#SBATCH --output=/N/scratch/ealamb/jum_%j.out
#SBATCH --error=/N/scratch/ealamb/jum_%j.err
#SBATCH --partition=general
#SBATCH --account=r01267
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --time=24:00:00
#SBATCH --cpus-per-task=16
#SBATCH --mem=32G

# ==========================

# Exit immediately if a command fails
set -e

# Load modules or activate environment
module load conda/25.3.0

#Imports shell setup
conda activate jum

#Make sure perl modules are available
export PERL5LIB=~/perl5/lib/perl5:$PERL5LIB
export PATH=~/perl5/bin:$PATH

#File paths
JUMA_SCRIPT="/N/slate/ealamb/GSF1440_1/jum/JUM_3.0.0/R_script_JUM.R"
JUMB_SCRIPT="/N/slate/ealamb/GSF1440_1/jum/JUM_3.0.0/JUM_B.sh"
JUMC_SCRIPT="/N/slate/ealamb/GSF1440_1/jum/JUM_3.0.0/JUM_C.sh"
DESIGN_FILE="/N/slate/ealamb/GSF1440_1/jum/experiment_design.txt"
A_OUT_FILE="/N/scratch/ealamb/A_outputFile.Rout"
A_ERR_FILE="/N/scratch/ealamb/A_errorFile.Rout"


echo "Starting JUM_a..."

# JUM A
Rscript ${JUMA_SCRIPT} ${DESIGN_FILE} \
--Analysis JUM_A \
--JuncThreshold 5 \
--Condition1_fileNum_threshold 1 \
--Condition2_fileNum_threshold 0 \
--IRthreshold 5 \
--Readlength 100 \
--Thread 3 \
> ${A_OUT_FILE} 2> ${A_ERR_FILE}

echo "Finished JUM_a successfully!"

echo "Starting JUM_b..."

bash ${JUMB_SCRIPT} --Folder /N/slate/ealamb/GSF1440_1/JUM_3.0.0 --Test pvalue --Cutoff 1 --TotalFileNum 3 --Condition1_fileNum_threshold 1 --Condition2_fileNum_threshold 0 --Condition1SampleName SRR24086912,SRR24086913 --Condition2SampleName SRR24086914

echo "Finished JUM_b successfully!"

echo "Starting JUM_c..."

bash ${JUMC_SCRIPT} --Folder /N/slate/ealamb/GSF1440_1/JUM_3.0.0 --Test pvalue --Cutoff 1 --TotalCondition1FileNum 2 --TotalCondition2FileNum 1 --REF /N/slate/ealamb/GSF1440_1/jum/refFlat.txt

echo "Finished JUM_c successfully!"



